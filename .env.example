# bili2txt-agent 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 飞书应用配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 临时文件目录
TEMP_DIR=./temp

# 飞书域名
FEISHU_DOMAIN=https://www.feishu.cn

# 飞书文档访问域名（用于生成文档分享链接）
# 注意：此配置不影响 API 调用，仅用于生成用户可访问的文档链接
# 中国大陆用户建议设置为：https://my.feishu.cn
# 海外版用户建议设置为：https://my.feishu.com
FEISHU_DOC_DOMAIN=https://my.feishu.cn

# 网络代理配置（可选）
# 如果您的网络环境需要代理才能访问飞书服务，请配置以下变量
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
