# ==============================================================================
# bili2txt-agent 环境变量配置示例
# ==============================================================================
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入实际的配置值（必需项必须填写，可选项使用默认值）
# 3. 确保 .env 文件不会被提交到版本控制系统（已在 .gitignore 中）
#
# 配置文档：https://github.com/yourusername/bili2txt-agent/docs/CONFIGURATION.md
#
# ==============================================================================

# ------------------------------------------------------------------------------
# 必需配置 (REQUIRED)
# ------------------------------------------------------------------------------

# 飞书应用配置
# 获取方式：访问 https://open.feishu.cn/ 创建企业自建应用
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API 基础 URL
# 说明：DeepSeek API 的访问地址
# 默认值：https://api.deepseek.com/v1
# 一般情况下无需修改
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek API 配置
# 获取方式：访问 https://platform.deepseek.com/ 获取 API Key
# 用途：文本精转、摘要生成
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# 可选配置 (OPTIONAL)
# ------------------------------------------------------------------------------

# 飞书 API 域名
# 说明：用于飞书 API 调用
# 默认值：https://open.feishu.cn
# 可选值：
#   - 中国大陆：https://open.feishu.cn
#   - 海外版：  https://open.larksuite.com
FEISHU_DOMAIN=https://open.feishu.cn

# 飞书文档访问域名
# 说明：用于生成用户可访问的文档分享链接
# 注意：此配置不影响 API 调用，仅影响返回给用户的文档链接格式
# 默认值：https://my.feishu.cn
# 可选值：
#   - 中国大陆：https://my.feishu.cn
#   - 海外版：  https://my.feishu.com 或 https://docs.larksuite.com
FEISHU_DOC_DOMAIN=https://my.feishu.cn

# 临时文件目录
# 说明：存放下载的音频、处理结果等临时文件
# 默认值：./temp
# 注意：确保程序对该目录有读写权限
TEMP_DIR=./temp

# ------------------------------------------------------------------------------
# 网络配置 (NETWORK)
# ------------------------------------------------------------------------------

# HTTP/HTTPS 代理配置
# 说明：如果您的网络环境需要代理才能访问外部服务
# 使用场景：企业内网、需要翻墙等
# 示例：http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ------------------------------------------------------------------------------
# 高级配置 (ADVANCED)
# ------------------------------------------------------------------------------

# Whisper 模型配置
# 说明：OpenAI Whisper 语音识别模型
# 默认模型：base（平衡速度和精度）
# 可选模型：tiny, base, small, medium, large
# 注意：更大的模型需要更多内存和处理时间
# WHISPER_MODEL=base

# 日志级别
# 说明：控制程序日志输出的详细程度
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认值：INFO
# LOG_LEVEL=INFO

# 文档格式配置
# 说明：生成文档时的格式选项
# 默认值：支持 Markdown 基础格式
# DOC_FORMAT=markdown

# ------------------------------------------------------------------------------
# 开发环境配置 (DEVELOPMENT)
# ------------------------------------------------------------------------------

# 开发模式
# 说明：启用开发模式时的额外调试信息
# 默认值：false
# DEBUG=false

# 测试模式
# 说明：跳过某些耗时操作，用于快速测试
# 默认值：false
# TEST_MODE=false

# ==============================================================================
# 配置验证
# ==============================================================================
#
# 启动前请确认：
# ✅ FEISHU_APP_ID 和 FEISHU_APP_SECRET 已填写
# ✅ DEEPSEEK_API_KEY 已填写
# ✅ FFmpeg 已安装（运行 ffmpeg -version 验证）
# ✅ Python 依赖已安装（运行 pip list 检查）
# ✅ 飞书应用已启用机器人能力
# ✅ 飞书应用已订阅 im.message.receive_v1 事件
# ✅ 飞书应用已授予必需权限（im:message, docx:document, drive:drive）
#
# ==============================================================================
